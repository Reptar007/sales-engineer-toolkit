// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// User Model Example
enum Role {
  admin
  sales_engineer_1
  sales_engineer_2
  sales_engineer_lead
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  firstName    String?
  lastName     String?
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // Relations
  salesEngineer     SalesEngineer?
  userRoles         UserRole[]
  googleIntegration UserGoogleIntegration?

  @@map("users")
}

/// Per-user Google Calendar OAuth tokens (refresh/access ciphertext only at rest).
model UserGoogleIntegration {
  id                   String    @id @default(cuid())
  userId               String    @unique
  googleSub            String?
  refreshTokenEnc      String
  accessTokenEnc       String?
  accessTokenExpiresAt DateTime?
  scopes               String?
  connectedAt          DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_google_integrations")
}

model UserRole {
  id        String   @id @default(cuid())
  userId    String
  role      Role
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, role])
  @@index([userId])
  @@index([role])
  @@map("user_roles")
}

model Team {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  salesEngineer     SalesEngineer? // One team = one SE
  accountExecutives AccountExecutive[]

  @@map("teams")
}

model SalesEngineer {
  id              String   @id @default(cuid())
  userId          String   @unique
  teamId          String   @unique
  salesforceEmail String?
  salesforceId    String?
  linearUserId    String?  @unique
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  team            Team             @relation(fields: [teamId], references: [id])
  teamAssignments TeamAssignment[]
  opps            Opp[]

  @@index([userId])
  @@index([teamId])
  @@map("sales_engineers")
}

model AccountExecutive {
  id              String   @id @default(cuid())
  name            String
  salesforceId    String   @unique
  salesforceEmail String?
  teamId          String
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  team            Team             @relation(fields: [teamId], references: [id])
  teamAssignments TeamAssignment[]

  @@index([teamId])
  @@index([salesforceId])
  @@map("account_executives")
}

model TeamAssignment {
  id                 String   @id @default(cuid())
  salesEngineerId    String
  accountExecutiveId String
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  // Relations
  salesEngineer    SalesEngineer    @relation(fields: [salesEngineerId], references: [id], onDelete: Cascade)
  accountExecutive AccountExecutive @relation(fields: [accountExecutiveId], references: [id], onDelete: Cascade)

  @@unique([salesEngineerId, accountExecutiveId])
  @@index([salesEngineerId])
  @@index([accountExecutiveId])
  @@map("team_assignments")
}

model QuarterlyGoal {
  id      String @id @default(cuid())
  year    Int
  quarter Int
  goal    Float

  @@unique([year, quarter])
  @@index([year])
  @@map("quarterly_goals")
}

/// Per-opportunity handoff page owned by a single SE. SE-authored content
/// (technical specs, notes, custom sections, people snapshots) lives here;
/// SF / Gong / Linear data is fetched live at read time and never persisted.
model Opp {
  id                      String  @id @default(cuid())
  salesEngineerId         String
  oppName                 String
  salesforceOpportunityId String?

  // People snapshots (plain strings -- CSMs / QA Leads typically aren't app users).
  aeNameOverride String?
  csmName        String?
  qaLeadName     String?
  qaManagerName  String?

  // SE-authored content. JSON blobs keep the schema flat and 1:1 with the
  // Notion page sync (one row -> one page).
  technicalSpecsJson String?
  // QAE team assignment (Alpacas / Badgers / etc.). Surfaces in the
  // Hunt Board handoff page and gets written to the Notion DB's
  // "QAE Team" select column on send.
  qawTeam            String?
  // SF stage snapshot. Refreshed by the FE whenever the detail page
  // hydrates Salesforce data so the Hunt Board directory can render a
  // stage pill without N synchronous SF queries on every list load.
  currentStage       String?
  stageSyncedAt      DateTime?
  notesMarkdown      String?
  customSectionsJson String?

  // Manually-linked Linear tickets -- JSON array of
  //   { identifier: "AXO-959", addedAt, addedByUserId }
  // resolved against Linear at read time so we never store stale state.
  manualLinearLinksJson String?

  // Test creation handoff details -- demo workspace + flows.
  //   { demoWorkspaceUrl: string, flows: [{ id, name, url }] }
  creationJson String?

  // Estimation handoff details.
  //   { type: 'ratio' | 'exploratory' | null,
  //     ratioDocUrl, exploratoryNotes, spreadsheetUrl }
  estimationJson String?

  // Notion handoff page. Populated the first time an SE clicks
  // "Send to Notion"; afterwards the FE shows "Open in Notion".
  notionPageId   String?
  notionPageUrl  String?
  notionSyncedAt DateTime?

  archivedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  salesEngineer SalesEngineer @relation(fields: [salesEngineerId], references: [id], onDelete: Cascade)

  @@unique([salesEngineerId, oppName])
  @@index([salesEngineerId])
  @@map("opps")
}
