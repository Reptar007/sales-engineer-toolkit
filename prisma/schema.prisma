// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// User Model Example
enum Role {
  admin
  sales_engineer_1
  sales_engineer_2
  sales_engineer_lead
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  firstName    String?
  lastName     String?
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // Relations
  salesEngineer     SalesEngineer?
  userRoles         UserRole[]
  googleIntegration UserGoogleIntegration?

  @@map("users")
}

/// Per-user Google Calendar OAuth tokens (refresh/access ciphertext only at rest).
model UserGoogleIntegration {
  id                   String    @id @default(cuid())
  userId               String    @unique
  googleSub            String?
  refreshTokenEnc      String
  accessTokenEnc       String?
  accessTokenExpiresAt DateTime?
  scopes               String?
  connectedAt          DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_google_integrations")
}

model UserRole {
  id        String   @id @default(cuid())
  userId    String
  role      Role
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, role])
  @@index([userId])
  @@index([role])
  @@map("user_roles")
}

model Team {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  salesEngineer     SalesEngineer? // One team = one SE
  accountExecutives AccountExecutive[]

  @@map("teams")
}

model SalesEngineer {
  id              String   @id @default(cuid())
  userId          String   @unique
  teamId          String   @unique
  salesforceEmail String?
  salesforceId    String?
  linearUserId    String?  @unique
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  team            Team             @relation(fields: [teamId], references: [id])
  teamAssignments TeamAssignment[]

  @@index([userId])
  @@index([teamId])
  @@map("sales_engineers")
}

model AccountExecutive {
  id              String   @id @default(cuid())
  name            String
  salesforceId    String   @unique
  salesforceEmail String?
  teamId          String
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  team            Team             @relation(fields: [teamId], references: [id])
  teamAssignments TeamAssignment[]

  @@index([teamId])
  @@index([salesforceId])
  @@map("account_executives")
}

model TeamAssignment {
  id                 String   @id @default(cuid())
  salesEngineerId    String
  accountExecutiveId String
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  // Relations
  salesEngineer    SalesEngineer    @relation(fields: [salesEngineerId], references: [id], onDelete: Cascade)
  accountExecutive AccountExecutive @relation(fields: [accountExecutiveId], references: [id], onDelete: Cascade)

  @@unique([salesEngineerId, accountExecutiveId])
  @@index([salesEngineerId])
  @@index([accountExecutiveId])
  @@map("team_assignments")
}

model QuarterlyGoal {
  id      String @id @default(cuid())
  year    Int
  quarter Int
  goal    Float

  @@unique([year, quarter])
  @@index([year])
  @@map("quarterly_goals")
}
