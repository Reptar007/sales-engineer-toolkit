# Sales Engineer Toolkit Environment Variables
# Use 1Password CLI to inject: op inject -i .env.example -o .env

# OpenAI Configuration
OPENAI_API_KEY="op://Shared - Sale Engineer/AI Keys/OpenAI"
OPENAI_MODEL=gpt-4o-mini

# Claude Configuration
ANTHROPIC_API_KEY="op://Shared - Sale Engineer/AI Keys/Anthropic"

# QA Wolf
QAW_BEARER_TOKEN="op://Shared - Sale Engineer/QAW Bearer Token/Token"

GOOGLE_SHEETS_CREDENTIALS="op://Shared - Sale Engineer/Google Docs Service Account/notesPlain"
GOOGLE_DOCS_TEMPLATE_ID="Ask sebastian"
GOOGLE_SHEETS_TEMPLATE_ID="Ask sebastian"

# Server Configuration
PORT=7071
NODE_ENV=development

# Salesforce Configuration
SALESFORCE_EMAIL="op://Shared - Sale Engineer/Salesforce/username"
SALESFORCE_PASSWORD="op://Shared - Sale Engineer/Salesforce/password"
SALESFORCE_TOKEN="op://Shared - Sale Engineer/Salesforce/Token"
SALESFORCE_LOGIN_URL="op://Shared - Sale Engineer/Salesforce/website"
# Optional: 2025 metrics report ID (defaults to 00OPA000002sLkf2AE if unset)
# SALESFORCE_REPORT_ID_METRICS_2025=
SALESFORCE_REPORT_ID_METRICS_2026="op://Shared - Sale Engineer/Salesforce/Report ID"
SALESFORCE_REPORT_ID_CALCULATOR="op://Shared - Sale Engineer/Salesforce/Calculator ID"

# Comma-separated years with snapshot data (e.g. 2025)
SNAPSHOT_YEARS=2025

DATABASE_URL="op://Shared - Sale Engineer/Prisma/Database URL"
JWT_SECRET="op://Shared - Sale Engineer/Prisma/JWT Secret"
JWT_EXPIRES_IN=7d

