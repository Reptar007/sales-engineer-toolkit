{
  "name": "sales-engineer-toolkit",
  "version": "1.0.0",
  "description": "A toolkit for sales engineers with ratio estimation capabilities",
  "main": "backend/src/index.js",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd backend && npm run dev",
    "dev:frontend": "cd frontend && npm run dev",
    "start": "cd backend && npm run start",
    "build": "npm run install:all && cd frontend && npm run build",
    "preview": "cd frontend && npm run preview",
    "env:refresh": "op inject -i .env.example -o .env",
    "env:setup": "./scripts/setup-env.sh",
    "test": "cd frontend && npm run test",
    "test:ui": "cd frontend && npm run test:ui",
    "test:coverage": "cd frontend && npm run test:coverage",
    "test:a11y": "cd frontend && npm run test:a11y",
    "test:visual": "cd frontend && npm run test:visual",
    "test:e2e": "cd frontend && npm run test:e2e",
    "test:ci": "cd frontend && npm run test:ci",
    "test:all": "cd frontend && npm run test:all",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prepare": "husky",
    "install:all": "npm install && cd backend && npm install && cd ../frontend && npm install"
  },
  "lint-staged": {
    "*.{js,mjs,cjs,json,md}": [
      "prettier --write"
    ],
    "*.js": [
      "eslint --fix"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Reptar007/sales-engineer-toolkit.git"
  },
  "bugs": {
    "url": "https://github.com/Reptar007/sales-engineer-toolkit/issues"
  },
  "homepage": "https://github.com/Reptar007/sales-engineer-toolkit#readme",
  "keywords": [
    "sales",
    "engineering",
    "ratio",
    "estimation",
    "toolkit"
  ],
  "author": "",
  "license": "ISC",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "csv-parser": "^3.2.0",
    "dotenv": "^17.2.1",
    "express": "^5.1.0",
    "openai": "^5.15.0",
    "redis": "^5.8.2",
    "socket.io": "^4.8.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.33.0",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "concurrently": "^9.1.0",
    "eslint": "^9.33.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-n": "^17.21.3",
    "eslint-plugin-promise": "^7.2.1",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.3.0",
    "husky": "^9.1.7",
    "less": "^4.4.1",
    "lint-staged": "^16.1.5",
    "nodemon": "^3.1.10",
    "papaparse": "^5.5.3",
    "prettier": "^3.6.2",
    "prop-types": "^15.8.1",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "vite": "^7.1.2"
  }
}
